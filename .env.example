# ─────────────────────────────────────────────────────────────────
# AI Hospital Operations Chief — LLM Configuration
# ─────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# The app works with any of the providers below.

# ── Active provider ──────────────────────────────────────────────
LLM_PROVIDER=openai          # openai | groq | deepseek | gemini | anthropic

LLM_API_KEY=your_api_key_here

# ── Model override (optional — sane default auto-selected if blank) ──
# LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────
# Provider-specific quick-start examples
# ─────────────────────────────────────────────────────────────────
#
# OpenAI
#   LLM_PROVIDER=openai
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o-mini          # or gpt-4o
#
# Groq  (free tier available at console.groq.com)
#   LLM_PROVIDER=groq
#   LLM_API_KEY=gsk_...
#   LLM_MODEL=llama-3.1-70b-versatile
#
# DeepSeek  (OpenAI-compatible)
#   LLM_PROVIDER=deepseek
#   LLM_API_KEY=sk-...
#   LLM_MODEL=deepseek-chat
#
# Google Gemini
#   LLM_PROVIDER=gemini
#   LLM_API_KEY=AIza...
#   LLM_MODEL=gemini-1.5-flash
#
# Anthropic Claude
#   LLM_PROVIDER=anthropic
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-3-5-haiku-20241022
# ─────────────────────────────────────────────────────────────────
